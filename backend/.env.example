# ================================
# Supabase Configuration
# ================================
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ================================
# AI Service APIs
# ================================
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Runway Gen-3 Alpha API
RUNWAY_API_KEY=your_runway_key_here

# ================================
# API Configuration
# ================================
API_VERSION=v1
API_PREFIX=/api/v1
PROJECT_NAME=DreamVision AI
ENVIRONMENT=development

# ================================
# Server Configuration
# ================================
HOST=0.0.0.0
PORT=8000

# ================================
# CORS Configuration
# ================================
# CORS Configuration (JSON array format!)
ALLOWED_ORIGINS=["http://localhost:19006", "http://localhost:8081", "exp://localhost:19000", "http://localhost:3000"]
# ================================
# Rate Limiting
# ================================
RATE_LIMIT_PER_MINUTE=10

# ================================
# Logging
# ================================
LOG_LEVEL=INFO

# ================================
# Storage Configuration
# ================================
STORAGE_BUCKET_THUMBNAILS=video-thumbnails
STORAGE_PUBLIC_URL=https://xxxxxxxxxxxxx.supabase.co/storage/v1/object/public

# ================================
# JWT Configuration (Supabase managed)
# ================================
JWT_SECRET=your-supabase-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ================================
# IMPORTANT NOTES
# ================================
# 1. NEVER commit .env file to git
# 2. Copy this to .env and fill in real values
# 3. Keep SUPABASE_SERVICE_KEY secret (backend only)
# 4. SUPABASE_ANON_KEY is safe for mobile app
# 5. Replace all "xxxxx" and "your_*_here" with actual values